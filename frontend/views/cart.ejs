<%- include('./partials/header') %>

<div class="w-full px-20 py-24">
    <h2 class="text-3xl font-bold mb-8">Shopping Cart</h2>

    <% if(user.cart.length > 0){ %>
        <div class="grid grid-cols-3 gap-8">

            <!-- Cart Items Section -->
            <div class="col-span-2">
                <div class="space-y-4">
                    <% user.cart.forEach(function(item){ %>
                        <% if(item.productId) { %>
                        <div class="w-full h-40 flex items-center gap-6 bg-white p-4 rounded-lg border border-gray-200 shadow-md hover:shadow-lg transition-shadow">

                            <!-- Product Image -->
                            <div class="w-40 h-full flex-shrink-0 flex items-center justify-center bg-[<%= item.productId.bgcolor %>] rounded">
                                <img class="h-[8rem]" src="data:image/jpeg;base64,<%= item.productId.image.toString('base64') %>" alt="<%= item.productId.name %>">
                            </div>

                            <!-- Product Details -->
                            <div class="flex-grow flex flex-col justify-between">
                                <div>
                                    <h3 class="text-lg font-semibold text-gray-800"><%= item.productId.name %></h3>
                                    <p class="text-sm text-gray-500">Price: ₹<%= item.productId.price %></p>
                                </div>

                                <!-- Quantity Controls -->
                                <div class="flex items-center gap-3">
                                    <a href="/decreasecart/<%= item.productId._id %>" class="w-7 h-7 flex items-center justify-center rounded-full bg-gray-200 hover:bg-gray-300">-</a>
                                    <div class="px-4 py-1 rounded-md bg-gray-100 text-center min-w-12"><%= item.quantity %></div>
                                    <a href="/addtocart/<%= item.productId._id %>" class="w-7 h-7 flex items-center justify-center rounded-full bg-gray-200 hover:bg-gray-300">+</a>
                                </div>
                            </div>

                            <!-- Subtotal -->
                            <div class="flex flex-col items-end justify-between h-full">
                                <span class="text-sm text-gray-500">Subtotal</span>
                                <p class="text-2xl font-bold text-green-600">₹<%= Number(item.productId.price) * item.quantity %></p>
                                <a href="/removecart/<%= item.productId._id %>" class="text-red-500 text-sm hover:text-red-700">Remove</a>
                            </div>
                        </div>
                        <% } %>
                    <% }) %>
                </div>
            </div>

            <!-- Price Breakdown Section -->
            <div class="col-span-1">
                <div class="bg-white p-6 rounded-lg border border-gray-200 shadow-md sticky top-24">
                    <h3 class="text-xl font-bold mb-6 pb-4 border-b border-gray-200">Price Breakdown</h3>

                    <div class="space-y-4">
                        <div class="flex justify-between text-gray-700">
                            <span>Total MRP</span>
                            <span>₹<%= typeof totalMRP !== 'undefined' ? totalMRP : 0 %></span>
                        </div>
                        <div class="flex justify-between text-gray-700">
                            <span>Discount</span>
                            <span class="text-green-600">-₹<%= typeof totalDiscount !== 'undefined' ? totalDiscount : 0 %></span>
                        </div>
                        <div class="flex justify-between text-gray-700">
                            <span>Platform Fee</span>
                            <span>₹<%= typeof platformFee !== 'undefined' ? platformFee : 20 %></span>
                        </div>
                        <div class="flex justify-between text-gray-700">
                            <span>Shipping</span>
                            <span class="text-green-600">FREE</span>
                        </div>
                    </div>

                    <div class="w-full h-[1px] bg-gray-300 my-6"></div>

                    <div class="flex justify-between items-center mb-6">
                        <h4 class="text-lg font-semibold text-gray-800">Total Amount</h4>
                        <h2 class="text-2xl font-bold text-green-600">₹<%= typeof bill !== 'undefined' ? bill : 20 %></h2>
                    </div>

                    <button class="w-full py-3 bg-blue-500 text-white font-semibold rounded-lg hover:bg-blue-600 transition">
                        Proceed to Checkout
                    </button>
                </div>
            </div>
        </div>

    <% } else { %>
        <div class="w-full h-96 flex flex-col items-center justify-center gap-4">
            <h2 class="text-2xl text-gray-500">Your cart is empty</h2>
            <a href="/shop" class="px-6 py-2 bg-blue-500 text-white rounded-lg hover:bg-blue-600">Continue Shopping</a>
        </div>
    <% } %>
</div>

<%- include('./partials/footer') %>